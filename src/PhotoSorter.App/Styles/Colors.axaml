<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Dark-mode palette per UI-Design.md ("Dark Mode" section).
        Defined as app-level resources (not overrides of FluentTheme's internal keys) so
        PhotoSorter's look doesn't depend on Avalonia theme internals, and so a future
        "Darstellung" settings page (Roadmap Phase 15) can swap these at runtime.
    -->
    <SolidColorBrush x:Key="PhotoSorterBackgroundBrush" Color="#202124" />
    <SolidColorBrush x:Key="PhotoSorterToolbarBrush" Color="#2B2B2B" />
    <SolidColorBrush x:Key="PhotoSorterAccentBrush" Color="#4A90E2" />
    <SolidColorBrush x:Key="PhotoSorterHighlightBrush" Color="Orange" />
    <SolidColorBrush x:Key="PhotoSorterTextBrush" Color="LightGray" />

    <!--
        Inter (the app-wide default font, via Avalonia.Fonts.Inter) has no glyphs for pictograph
        symbols like folder/gear/question-mark (their Unicode default is "emoji presentation",
        outside a plain text sans font's coverage) - only dingbats with default *text* presentation
        (e.g. the checkmark used on "Anwenden") render without this. Listing each platform's native
        color-emoji font ahead of Inter lets Avalonia's per-glyph font fallback resolve the icon
        characters correctly while regular label text still falls through to Inter as before.
    -->
    <FontFamily x:Key="PhotoSorterIconFontFamily">Segoe UI Emoji,Apple Color Emoji,Noto Color Emoji,Inter</FontFamily>
</ResourceDictionary>
