<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhotoSorter.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="32"
             x:Class="PhotoSorter.App.Views.StatusBarView"
             x:DataType="vm:StatusBarViewModel">

    <Border Background="{StaticResource PhotoSorterToolbarBrush}" Padding="8,4">
        <StackPanel Orientation="Horizontal" Spacing="16">
            <TextBlock Text="{Binding ImagePositionDisplay}" Foreground="{StaticResource PhotoSorterTextBrush}" />
            <TextBlock Text="{Binding LeftCount, StringFormat='Links: {0}'}" Foreground="{StaticResource PhotoSorterTextBrush}" />
            <TextBlock Text="{Binding RightCount, StringFormat='Rechts: {0}'}" Foreground="{StaticResource PhotoSorterTextBrush}" />
            <TextBlock Text="{Binding OpenCount, StringFormat='Offen: {0}'}" Foreground="{StaticResource PhotoSorterTextBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding ZoomPercentage, StringFormat='Zoom: {0} %'}"
                           Foreground="{StaticResource PhotoSorterTextBrush}" />
                <Button Content="↺"
                        FontFamily="{StaticResource PhotoSorterIconFontFamily}"
                        Padding="4,0"
                        Command="{Binding ResetZoomCommand}"
                        ToolTip.Tip="Zoom auf „Bild einpassen“ zurücksetzen" />
            </StackPanel>
            <TextBlock Text="{Binding CurrentFileName}" Foreground="{StaticResource PhotoSorterTextBrush}" />
        </StackPanel>
    </Border>

</UserControl>
