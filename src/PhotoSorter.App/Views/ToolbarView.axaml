<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhotoSorter.Core.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="48"
             x:Class="PhotoSorter.App.Views.ToolbarView"
             x:DataType="vm:ToolbarViewModel">

    <Border Background="{StaticResource PhotoSorterToolbarBrush}" Padding="8">
        <!-- Three-zone layout: Quelle stays left-aligned, Anwenden is centered in the whole
             toolbar (equal-star columns 0/2 do that regardless of how wide each side's content
             is), Hilfe+Einstellungen are grouped at the right edge with Einstellungen last. -->
        <Grid ColumnDefinitions="*,Auto,*">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                <Button Content="📁 Quelle"
                        FontFamily="{StaticResource PhotoSorterIconFontFamily}"
                        Command="{Binding SelectSourceFolderCommand}"
                        ToolTip.Tip="Quellordner auswählen (rekursiv nach Bildern durchsucht)" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Content="✔ Anwenden"
                        FontFamily="{StaticResource PhotoSorterIconFontFamily}"
                        Command="{Binding ApplyCommand}"
                        ToolTip.Tip="Alle Sortierentscheidungen anwenden (Dateien verschieben bzw. in den Papierkorb legen)" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="❓ Hilfe"
                        FontFamily="{StaticResource PhotoSorterIconFontFamily}"
                        Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="Aktuelle Tastenkürzel anzeigen" />
                <Button Content="⚙ Einstellungen"
                        FontFamily="{StaticResource PhotoSorterIconFontFamily}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip.Tip="Hotkeys, Darstellung, Zielordner und Animationen anpassen" />
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
