<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhotoSorter.Core.ViewModels"
        xmlns:views="using:PhotoSorter.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="PhotoSorter.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Background="{StaticResource PhotoSorterBackgroundBrush}"
        MinWidth="800"
        MinHeight="500"
        Title="PhotoSorter">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <views:ToolbarView Grid.Row="0" DataContext="{Binding ToolbarViewModel}" />
        <views:ThumbnailBarView Grid.Row="1" DataContext="{Binding ThumbnailBarViewModel}" />
        <views:ImageViewerView Grid.Row="2" DataContext="{Binding ImageViewerViewModel}" />
        <views:StatusBarView Grid.Row="3" DataContext="{Binding StatusBarViewModel}" />
    </Grid>

</Window>
